# ── TravelingApp Compose ─────────────────────────
COMPOSE_PROJECT_NAME=traveling-app-compose

# App
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=80
TRAVELINGAPP_PORT=5090

# JWT
JWT_KEY=super-secret-key-at-least-32-chars-long-for-production!
JWT_ISSUER=TravelAuth
JWT_AUDIENCE=TravelAPI
JWT_EXPIRE_MINUTES=60

# PostgreSQL
POSTGRES_PORT=5434
POSTGRES_DB=TravelingAppDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_PORT=6380

# Resources
LIMIT_CPUS=1.0
LIMIT_MEMORY=512M
RESERVE_CPUS=0.5
RESERVE_MEMORY=256M
